# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Desenvolvimento local (SQLite — trocar para postgresql antes do deploy):
DATABASE_URL="file:./dev.db"

# Produção (PostgreSQL — Railway, Supabase, Neon, etc.):
# DATABASE_URL="postgresql://user:password@host:5432/autoestetia_pro?schema=public"
# Atenção: trocar também o provider no prisma/schema.prisma para "postgresql"

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Gere valores fortes com: openssl rand -hex 64
JWT_SECRET="troque-por-valor-aleatorio-de-64-bytes"
JWT_REFRESH_SECRET="troque-por-outro-valor-aleatorio-de-64-bytes"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV="production"

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"

# ─── Cloudflare R2 (armazenamento em nuvem — opcional, mas recomendado em prod) ──
# Sem essas variáveis, uploads ficam no disco local (ephemero no Railway!)
# R2_ACCOUNT_ID="seu_account_id"
# R2_ACCESS_KEY_ID="sua_access_key"
# R2_SECRET_ACCESS_KEY="sua_secret_key"
# R2_BUCKET_NAME="autoestetia-uploads"
# R2_PUBLIC_URL="https://pub-xxx.r2.dev"  # URL pública do bucket

# ─── E-mail transacional (Resend.com — recomendado) ──────────────────────────
# 1. Crie conta grátis em resend.com (3.000 e-mails/mês)
# 2. Vá em API Keys → Create API Key → copie a chave
# 3. Enquanto não tiver domínio próprio: SMTP_FROM deve usar onboarding@resend.dev
#    (só consegue enviar para o seu próprio e-mail no plano grátis sem domínio)
# 4. Após comprar domínio: verifique em resend.com/domains e use seu e-mail
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="resend"
SMTP_PASS="re_xxxxxxxxxxxxxxxxxxxx"
SMTP_FROM="AutoEstética Pro <onboarding@resend.dev>"

# ─── Notificações do dono (leads da landing page) ────────────────────────────
OWNER_EMAIL="gabrieldejesusf10@gmail.com"

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL="https://seudominio.vercel.app"
CORS_ORIGINS="https://seudominio.vercel.app"

# ─── Super Admin (painel /admin) ─────────────────────────────────────────────
SUPER_ADMIN_SECRET="gere-com-openssl-rand-hex-64"
